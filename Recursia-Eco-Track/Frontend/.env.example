# =============================================================================
# EcoTrack Frontend Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your actual values

# =============================================================================
# API CONFIGURATION
# =============================================================================
# Backend API base URL
VITE_API_URL=http://localhost:3000/api

# =============================================================================
# MAPBOX INTEGRATION (Optional)
# =============================================================================
# Mapbox access token for maps and geocoding
# Get your free token at: https://account.mapbox.com/access-tokens/
VITE_MAPBOX_ACCESS_TOKEN=

# =============================================================================
# DEVELOPMENT FLAGS
# =============================================================================
# Enable debug mode for additional console logging
VITE_DEBUG_MODE=true

# =============================================================================
# APPLICATION METADATA
# =============================================================================
# Application name (displayed in UI)
VITE_APP_NAME=EcoTrack
# Application version
VITE_APP_VERSION=1.0.0

# =============================================================================
# SOCKET.IO CONFIGURATION
# =============================================================================
# Socket.IO server URL (usually same as API URL without /api)
VITE_SOCKET_URL=http://localhost:3000